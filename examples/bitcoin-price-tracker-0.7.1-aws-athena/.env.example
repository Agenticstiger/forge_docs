## AWS Configuration for Bitcoin Price Tracker
## Copy to .env and fill in real values: cp .env.example .env
##
## In Jenkins CI, these are set automatically:
##   AWS_REGION  → from pipeline param (default: eu-central-1)
##   S3_BUCKET   → from pipeline param, or auto-derived as {account_id}-fluid-data
##   AWS creds   → from Jenkins 'aws-credentials' credential store

export AWS_REGION="eu-central-1"
export AWS_ACCESS_KEY_ID="your_access_key"
export AWS_SECRET_ACCESS_KEY="your_secret_key"

# Leave empty to auto-derive as {account_id}-fluid-data (matches planner convention)
export S3_BUCKET="your-fluid-data-bucket"
