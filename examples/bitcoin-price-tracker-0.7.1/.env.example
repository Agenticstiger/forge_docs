## GCP Configuration for Bitcoin Price Tracker
## Copy to .env and fill in real values: cp .env.example .env
##
## In Jenkins CI, credentials are loaded automatically:
##   GOOGLE_APPLICATION_CREDENTIALS → from Jenkins 'gcp-service-account'
##   GCP_PROJECT → auto-derived from service account key

export GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
export GCP_PROJECT="your-gcp-project-id"
