# Snowflake Connection Configuration
# Copy this file to .env and fill in your credentials

export SNOWFLAKE_ACCOUNT="YOUR-ACCOUNT-ID"          # e.g., "ABC12345" or "myorg-account"
export SNOWFLAKE_USER="YOUR-USERNAME"                # e.g., "pipeline_user"
export SNOWFLAKE_PASSWORD="YOUR-PASSWORD"            # Strong password
export SNOWFLAKE_WAREHOUSE="COMPUTE_WH"              # Virtual warehouse name
export SNOWFLAKE_ROLE="SYSADMIN"                     # Role with CREATE DATABASE permissions

# Optional: Override contract defaults
# export SNOWFLAKE_DATABASE="CRYPTO_DATA"
# export SNOWFLAKE_SCHEMA="MARKET_DATA"
# export SNOWFLAKE_TABLE="BITCOIN_PRICES"

# Notes:
# 1. NEVER commit .env file to git (it's in .gitignore)
# 2. For production, use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# 3. The SYSADMIN role needs:
#    - USAGE and OPERATE on the warehouse
#    - CREATE DATABASE privilege
# 4. Get your account ID from: https://app.snowflake.com/
